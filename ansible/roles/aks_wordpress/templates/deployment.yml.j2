apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ container_name }}
  namespace: {{ k8s_namespace }}

spec:
  replicas: {{ replicas }}

  selector:
    matchLabels:
      app: {{ container_name }}
  template:
    metadata:
      labels:
        app: {{ container_name }}

    spec:
      imagePullSecrets:
        - name: {{ acr_secret_name }}

      containers:
        - name: {{ container_name }}
          image: {{ acr_server }}/{{ image_name }}:{{ image_tag }}

          ports:
            - containerPort: {{ container_port }}
              name: {{ container_name }}-port

          env:
            - name: WORDPRESS_DB_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ wordpress_secret_name }}
                  key: WORDPRESS_DB_PASSWORD

            - name: WORDPRESS_DB_HOST
              valueFrom:
                configMapKeyRef:
                  name: {{ wordpress_config_name }}
                  key: WORDPRESS_DB_HOST

            - name: WORDPRESS_DB_USER
              valueFrom:
                configMapKeyRef:
                  name: {{ wordpress_config_name }}
                  key: WORDPRESS_DB_USER

          volumeMounts:
            - name: {{ volume_name }}
              mountPath: {{ volume_mount_path }}

      volumes:
        - name: {{ volume_name }}
          persistentVolumeClaim:
            claimName: {{ pvc_name }}